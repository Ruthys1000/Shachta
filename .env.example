DATABASE_URL="postgresql://user:password@localhost:5432/arabic_tutor"
# Optional: direct (non-pooled) connection used only for `prisma migrate deploy`.
# On serverless Postgres with a pooler (e.g. Neon), set this to the DIRECT/unpooled
# connection string to avoid P1002 advisory-lock timeouts during deploy. If unset,
# migrations fall back to DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/arabic_tutor"
ANTHROPIC_API_KEY="sk-ant-..."
APP_PASSWORD="choose-a-password"
SESSION_SECRET="generate-a-long-random-string"
# Daily spending cap (USD) for Anthropic API usage. Defaults to 5 if unset.
AI_DAILY_BUDGET_USD="5"
# Stricter daily cap (USD) for the read-only demo login (code: orly-demo), tracked
# separately from the owner's spend. Defaults to 1 if unset.
AI_DEMO_DAILY_BUDGET_USD="1"
