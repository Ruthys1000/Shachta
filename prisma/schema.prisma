generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ItemType {
  WORD
  PHRASE
  SENTENCE
}

model Vocabulary {
  id             String   @id @default(uuid())
  arabicTranslit String   @map("arabic_translit")
  hebrewMeaning  String   @map("hebrew_meaning")
  itemType       ItemType @map("item_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  practiceHistory PracticeHistory?

  @@unique([arabicTranslit])
  @@map("vocabulary")
}

model PracticeHistory {
  id            String     @id @default(uuid())
  vocabularyId  String     @unique @map("vocabulary_id")
  vocabulary    Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  correctCount  Int        @default(0) @map("correct_count")
  wrongCount    Int        @default(0) @map("wrong_count")
  lastPracticed DateTime?  @map("last_practiced")

  @@map("practice_history")
}

model SentenceLessonHistory {
  id           String   @id @default(uuid())
  title        String
  correctCount Int      @default(0) @map("correct_count")
  wrongCount   Int      @default(0) @map("wrong_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("sentence_lesson_history")
}

model GrammarLessonHistory {
  id           String   @id @default(uuid())
  title        String
  focus        String
  correctCount Int      @default(0) @map("correct_count")
  wrongCount   Int      @default(0) @map("wrong_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("grammar_lesson_history")
}

model StoryHistory {
  id           String   @id @default(uuid())
  title        String
  theme        String
  correctCount Int      @default(0) @map("correct_count")
  wrongCount   Int      @default(0) @map("wrong_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("story_history")
}

model AppSettings {
  id               String    @id @default("singleton")
  placementLevel   Int?      @map("placement_level")
  placementScore   Int?      @map("placement_score")
  placementTotal   Int?      @map("placement_total")
  placementTakenAt DateTime? @map("placement_taken_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("app_settings")
}

model AiUsageLog {
  id           String   @id @default(uuid())
  route        String
  role         String   @default("owner")
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costUsd      Float    @map("cost_usd")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_usage_log")
}
